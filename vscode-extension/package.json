{
  "name": "git-ai",
  "displayName": "Git AI - Async Commit Polisher",
  "description": "AI-powered Git commit message enhancer — status, controls, and logs directly in VS Code",
  "version": "0.3.7",
  "publisher": "git-ai-async-commit-polisher",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/daidi/git-ai"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "ai",
    "commit",
    "conventional-commits",
    "gitmoji"
  ],
  "icon": "resources/icon.png",
  "activationEvents": [
    "workspaceContains:.git"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "git-ai.init",
        "title": "%command.init%",
        "category": "git-ai"
      },
      {
        "command": "git-ai.retry",
        "title": "%command.retry%",
        "category": "git-ai"
      },
      {
        "command": "git-ai.undo",
        "title": "%command.undo%",
        "category": "git-ai"
      },
      {
        "command": "git-ai.cancel",
        "title": "%command.cancel%",
        "category": "git-ai"
      },
      {
        "command": "git-ai.forcePush",
        "title": "%command.forcePush%",
        "category": "git-ai"
      },
      {
        "command": "git-ai.showLogs",
        "title": "%command.showLogs%",
        "category": "git-ai"
      },
      {
        "command": "git-ai.openConfig",
        "title": "%command.openConfig%",
        "category": "git-ai"
      },
      {
        "command": "git-ai.uninstall",
        "title": "%command.uninstall%",
        "category": "git-ai"
      },
      {
        "command": "git-ai.skipNextCommit",
        "title": "%command.skipNextCommit%",
        "category": "git-ai"
      }
    ],
    "icons": {
      "git-ai-zap": {
        "description": "Zap icon for git-ai",
        "default": {
          "fontPath": "./node_modules/@vscode/codicons/dist/codicon.ttf",
          "fontCharacter": "\\eb66"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "git-ai",
          "title": "Git AI",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "git-ai": [
        {
          "id": "git-ai.status",
          "name": "Status"
        },
        {
          "id": "git-ai.actions",
          "name": "Actions",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Git AI",
      "properties": {
        "git-ai.pollingInterval": {
          "type": "number",
          "default": 1000,
          "description": "State file polling interval in milliseconds"
        },
        "git-ai.binaryPath": {
          "type": "string",
          "default": "git-ai",
          "description": "Path to the git-ai binary"
        },
        "git-ai.notificationMode": {
          "type": "string",
          "enum": [
            "sound",
            "silentToast",
            "silentStatus"
          ],
          "default": "sound",
          "description": "How notifications are displayed"
        }
      }
    },
    "submenus": [
      {
        "id": "git-ai.scmMenu",
        "label": "%submenu.gitai%",
        "icon": "$(zap)"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "submenu": "git-ai.scmMenu",
          "group": "navigation"
        }
      ],
      "git-ai.scmMenu": [
        {
          "command": "git-ai.retry",
          "group": "1_actions"
        },
        {
          "command": "git-ai.undo",
          "group": "1_actions"
        },
        {
          "command": "git-ai.cancel",
          "group": "1_actions"
        },
        {
          "command": "git-ai.forcePush",
          "group": "1_actions"
        },
        {
          "command": "git-ai.skipNextCommit",
          "group": "1_actions"
        },
        {
          "command": "git-ai.init",
          "group": "2_config"
        },
        {
          "command": "git-ai.openConfig",
          "group": "2_config"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "publish": "vsce publish",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45"
  }
}
