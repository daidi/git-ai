<idea-plugin>
    <id>com.daidi.gitai</id>
    <name>Git AI - Async Commit Polisher</name>
    <vendor email="daidi88@sina.com" url="https://github.com/daidi/git-ai">daidi</vendor>

    <description><![CDATA[
    <h3>Commit first, think later.</h3>
    <br/>
    <p>Never wait for an AI to generate your commit messages again. <b>Git AI</b> hooks into your normal Git workflow and uses LLMs (DeepSeek, OpenAI, Ollama) to rewrite your commit messages into clean, Conventional Commits — completely asynchronously.</p>
    <br/>
    <p>You write <code>git commit -m "fix bug"</code>, and just keep coding. Seconds later, it becomes <code>fix(auth): resolve session timeout on mobile devices</code> silently in the background.</p>
    <br/>
    <p><b>Features:</b></p>
    <ul>
        <li><b>Zero Friction</b> — Immediate IDE state snapshot tracking so your code is instantly safe without blocking your terminal or IDE flow.</li>
        <li><b>Deferred Priority Push</b> — Pushes are automatically queued if AI is working, and executed silently when polishing finishes.</li>
        <li><b>Live Status Bar Widget</b> — See instantly if the Git AI daemon is polishing right at the bottom of the IDE.</li>
        <li><b>Tool Window & Logs</b> — Real-time daemon logs and tracing directly inside IntelliJ.</li>
        <li><b>Commit History UI</b> — Native actions to Undo changes, Retry polishing, or cancel requests.</li>
        <li><b>Visual Settings</b> — Configure API keys and providers (DeepSeek, OpenAI, local Ollama) inside Preferences with i18n support.</li>
    </ul>
    <br/>

    ]]></description>

    <change-notes><![CDATA[
        <ul>
            <li>Initial release of Git AI</li>
        </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>

    <resource-bundle>messages.GitAiBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Startup activity to begin state watching -->
        <postStartupActivity
                implementation="com.daidi.gitai.GitAiStartupActivity"/>

        <!-- Status bar widget -->
        <statusBarWidgetFactory
                id="GitAiStatusWidget"
                implementation="com.daidi.gitai.ui.GitAiStatusWidgetFactory"
                order="after positionWidget"/>

        <!-- Tool window for logs and state -->
        <toolWindow
                id="Git AI"
                anchor="bottom"
                icon="com.daidi.gitai.Icons.GitAi"
                factoryClass="com.daidi.gitai.ui.GitAiToolWindowFactory"/>

        <!-- Project-level service for state management -->
        <projectService
                serviceImplementation="com.daidi.gitai.state.GitAiStateService"/>

        <!-- Notification group -->
        <notificationGroup
                id="git-ai.notifications"
                displayType="BALLOON"
                toolWindowId="Git AI"/>

        <!-- Settings page: Settings → Tools → git-ai -->
        <projectConfigurable
                parentId="tools"
                id="com.daidi.gitai.settings"
                displayName="Git AI"
                instance="com.daidi.gitai.settings.GitAiSettingsConfigurable"/>
    </extensions>

    <actions>
        <group id="GitAi.ActionGroup" popup="true"
               icon="com.daidi.gitai.Icons.GitAi">
            <add-to-group group-id="VcsGlobalGroup" anchor="last"/>
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="last"/>

            <action id="GitAi.SkipNextCommit"
                    class="com.daidi.gitai.actions.SkipNextCommitAction"
                    icon="AllIcons.Actions.Suspend"/>


            <action id="GitAi.Retry"
                    class="com.daidi.gitai.actions.RetryAction"
                    icon="AllIcons.Actions.Refresh"/>

            <action id="GitAi.Undo"
                    class="com.daidi.gitai.actions.UndoAction"
                    icon="AllIcons.Actions.Undo"/>

            <action id="GitAi.Cancel"
                    class="com.daidi.gitai.actions.CancelAction"
                    icon="AllIcons.Actions.Cancel"/>

            <action id="GitAi.ForcePush"
                    class="com.daidi.gitai.actions.ForcePushAction"
                    icon="AllIcons.Vcs.Push"/>

            <action id="GitAi.Init"
                    class="com.daidi.gitai.actions.InitAction"
                    icon="AllIcons.General.Add"/>

            <action id="GitAi.OpenConfig"
                    class="com.daidi.gitai.actions.OpenConfigAction"
                    icon="AllIcons.General.Settings"/>
        </group>
    </actions>
</idea-plugin>
